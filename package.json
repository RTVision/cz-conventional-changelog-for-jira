{
  "name": "@rtvision/cz-conventional-changelog-for-jira",
  "version": "0.0.3",
  "description": "Commitizen adapter following the conventional-changelog format and also asking for JIRA issue.",
  "homepage": "https://github.com/rtvision/cz-conventional-changelog-for-jira",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rtvision/cz-conventional-changelog-for-jira.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "imports": {
    "#src/*.js": "./src/*.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./configurable": {
      "types": "./dist/configurable.d.ts",
      "default": "./dist/configurable.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck",
    "commit": "git-cz",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "prepack": "tsdown",
    "semantic-release": "semantic-release",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "commitizen": "^4.3.1",
    "inquirer": "^8.2.7",
    "word-wrap": "^1.2.5"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@typescript/native-preview": "7.0.0-dev.20260317.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "semantic-release": "^24.2.9",
    "tsdown": "^0.21.4",
    "vitest": "^4.1.0"
  },
  "optionalDependencies": {
    "@commitlint/load": "^20.5.0"
  },
  "config": {
    "commitizen": {
      "path": "./dist/index.js",
      "jiraMode": false,
      "skipScope": true
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.29.3"
}
